# =============================================================================
# RAD-ML  ·  Generated Model Endpoint — Docker Image
# =============================================================================
#
# This Dockerfile packages the Streamlit prediction app that is produced by the
# RAD-ML chatbot pipeline (workspace/current_app/).
#
# The image exposes one environment variable the deployment workflow must set:
#   SAGEMAKER_ENDPOINT  — name of the SageMaker endpoint to invoke
#
# AWS credentials (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION) are
# injected at runtime by the CI/CD workflow and are NEVER baked into the image.
#
# To run locally (mock mode, no real SageMaker):
#   docker build -t radml-model-endpoint .
#   docker run -p 8501:8501 -e RADML_MOCK_MODE=1 radml-model-endpoint
#
# To run against a live SageMaker endpoint:
#   docker run -p 8501:8501 \
#     -e SAGEMAKER_ENDPOINT=rad-ml-endpoint \
#     -e AWS_ACCESS_KEY_ID=... \
#     -e AWS_SECRET_ACCESS_KEY=... \
#     -e AWS_REGION=us-east-1 \
#     radml-model-endpoint
# =============================================================================

# ── Stage 1: Build dependencies ───────────────────────────────────────────────
FROM python:3.11-slim AS builder

# Build args written into image labels by the CI/CD pipeline
ARG BUILD_DATE="unknown"
ARG GIT_COMMIT="unknown"

WORKDIR /build

# Install only the build-time system packages we need
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies first (layer-cache friendly)
COPY requirements.txt* ./
# If no requirements.txt was generated by the chatbot, fall back to the minimal set
RUN if [ -f requirements.txt ]; then \
        pip install --no-cache-dir --prefix=/install -r requirements.txt; \
    else \
        pip install --no-cache-dir --prefix=/install \
            streamlit \
            boto3 \
            pandas \
            numpy \
            scikit-learn \
            pyyaml \
            python-dotenv; \
    fi

# ── Stage 2: Runtime image ────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

ARG BUILD_DATE="unknown"
ARG GIT_COMMIT="unknown"

# OCI image labels
LABEL org.opencontainers.image.title="RAD-ML Model Endpoint" \
      org.opencontainers.image.description="Streamlit inference app generated by the RAD-ML chatbot" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${GIT_COMMIT}" \
      maintainer="RAD-ML CI/CD"

# Runtime system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy installed Python packages from builder stage
COPY --from=builder /install /usr/local

# Create a non-root user to run the app (security best practice)
RUN useradd -m -u 1000 -s /bin/bash appuser

WORKDIR /app

# Copy the generated app files
COPY --chown=appuser:appuser . .

# Create Streamlit config directory for the non-root user
RUN mkdir -p /home/appuser/.streamlit && \
    chown -R appuser:appuser /home/appuser/.streamlit

# Write the Streamlit server config.  These settings:
#   - Disable the 'Deploy to Streamlit Cloud' prompt in the header
#   - Disable telemetry
#   - Set headless mode (required for Docker)
RUN cat > /home/appuser/.streamlit/config.toml << 'EOF'
[server]
headless = true
port = 8501
address = "0.0.0.0"
enableCORS = false
enableXsrfProtection = true

[browser]
gatherUsageStats = false

[runner]
fastReruns = true
EOF

# Switch to non-root user
USER appuser

# Streamlit health-check endpoint (used by Docker and the CI/CD monitor job)
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:8501/_stcore/health || exit 1

EXPOSE 8501

# ── Environment variable defaults ─────────────────────────────────────────────
#   Override these at 'docker run' time or via the CI/CD workflow secrets.
ENV SAGEMAKER_ENDPOINT=""
ENV AWS_REGION="us-east-1"
ENV AWS_EC2_METADATA_DISABLED="true"
ENV SAGEMAKER_REMOTE_ENABLED="1"
ENV RADML_MOCK_MODE="0"

ENTRYPOINT ["streamlit", "run", "app.py", \
            "--server.port=8501", \
            "--server.address=0.0.0.0", \
            "--server.headless=true"]
